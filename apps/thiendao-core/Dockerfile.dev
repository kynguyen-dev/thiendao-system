# ─── Thiên Đạo Core — Development Dockerfile ─────────────────────
# Minimal image: only Node.js + pnpm. NO dependency install here.
# Dependencies are installed at CONTAINER STARTUP via the command
# in docker-compose.yml: "pnpm install && pnpm dev"
# This means new packages are picked up without rebuilding the image.
# ──────────────────────────────────────────────────────────────────

FROM node:20-alpine

# ─── Install pnpm via corepack ───────────────────────────────────
RUN corepack enable && corepack prepare pnpm@10.32.1 --activate

# ─── Monorepo root (bind-mounted at runtime) ─────────────────────
WORKDIR /app

# ─── Expose API port ─────────────────────────────────────────────
EXPOSE 3000

# ─── Default command (overridden by docker-compose) ──────────────
CMD ["sh", "-c", "pnpm install && pnpm run dev"]
